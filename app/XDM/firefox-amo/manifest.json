{
    "name": "TheDownload Manager Browser Helper",
    "browser_action": {},
    "manifest_version": 2,
    "version": "1.4",
    "description": "Download files with TheDownload Manager by Rincol Tech.",
    "permissions": [
        "tabs",
        "cookies",
        "contextMenus",
        "menus",
        "activeTab",
        "webRequest",
        "webRequestBlocking",
        "*://*/*"
    ],
    "background": {
        "page": "main.html"
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "tdm-browser-helper@rincoltech.com"
        }
    }
}